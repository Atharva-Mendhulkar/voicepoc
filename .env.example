# ── MODE SWITCH ──────────────────────────────────────────────────────
# Values: livekit | pipecat | hybrid
AGENT_MODE=hybrid

# ── LiveKit ──────────────────────────────────────────────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-32-character-long-secure-secret-key

# ── Provider selection ───────────────────────────────────
STT_PROVIDER=deepgram
TTS_PROVIDER=cartesia
LLM_PROVIDER=openai

# ── STT ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=
AGENT_LANGUAGE=hi

# ── TTS ──────────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ── LLM ──────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Optional alternatives ─────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
